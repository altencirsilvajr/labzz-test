{
  "name": "labzz/chat-backend",
  "description": "Real-time chat backend monolith in custom PHP 8.3",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-sodium": "*",
    "nikic/fast-route": "^1.3",
    "nyholm/psr7": "^1.8",
    "nyholm/psr7-server": "^1.1",
    "psr/http-message": "^2.0",
    "doctrine/dbal": "^4.2",
    "doctrine/migrations": "^3.8",
    "monolog/monolog": "^3.6",
    "predis/predis": "^2.3",
    "elasticsearch/elasticsearch": "^8.13",
    "firebase/php-jwt": "^6.10",
    "guzzlehttp/guzzle": "^7.9",
    "ramsey/uuid": "^4.7",
    "symfony/dotenv": "^7.2",
    "symfony/cache": "^7.2",
    "promphp/prometheus_client_php": "^2.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "audit": {
      "block-insecure": false
    }
  }
}
